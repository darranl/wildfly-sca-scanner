{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wildfly.org/schemas/cve-report-v1.0.json",
  "title": "WildFly CVE Report",
  "description": "Generic CVE report format for WildFly SCA Scanner",
  "type": "object",
  "required": ["schemaVersion", "metadata", "vulnerabilities", "summary"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (e.g., '1.0')"
    },
    "metadata": {
      "type": "object",
      "required": ["scanDate", "wildflyVersion", "scanners"],
      "properties": {
        "scanDate": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of scan"
        },
        "wildflyVersion": {
          "type": "string",
          "description": "WildFly version scanned"
        },
        "scanners": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version"],
            "properties": {
              "name": {"type": "string"},
              "version": {"type": "string"}
            }
          }
        },
        "totalDependencies": {
          "type": "integer",
          "minimum": 0
        },
        "vulnerableDependencies": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "vulnerabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "severity", "description", "affectedPackages"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CVE-\\d{4}-\\d+$"
          },
          "source": {"type": "string"},
          "title": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
          },
          "cvssScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "cvssVector": {"type": "string"},
          "description": {"type": "string"},
          "publishedDate": {
            "type": "string",
            "format": "date"
          },
          "cwe": {
            "type": "array",
            "items": {"type": "string"}
          },
          "affectedPackages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["packageUrl"],
              "properties": {
                "packageUrl": {"type": "string"},
                "groupId": {"type": "string"},
                "artifactId": {"type": "string"},
                "version": {"type": "string"},
                "filePath": {"type": "string"}
              }
            }
          },
          "references": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url"],
              "properties": {
                "url": {"type": "string", "format": "uri"},
                "source": {"type": "string"},
                "name": {"type": "string"}
              }
            }
          },
          "suppressed": {"type": "boolean"},
          "suppressionReason": {"type": ["string", "null"]},
          "comments": {"type": ["string", "null"]},
          "mitigations": {"type": ["string", "null"]}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["critical", "high", "medium", "low", "suppressed", "active"],
      "properties": {
        "critical": {"type": "integer", "minimum": 0},
        "high": {"type": "integer", "minimum": 0},
        "medium": {"type": "integer", "minimum": 0},
        "low": {"type": "integer", "minimum": 0},
        "suppressed": {"type": "integer", "minimum": 0},
        "active": {"type": "integer", "minimum": 0}
      }
    }
  }
}